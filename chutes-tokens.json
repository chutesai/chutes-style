{
  "name": "Chutes",
  "derivedFrom": "chutes-web",
  "capturedOn": "2026-04-02",
  "selfContained": true,
  "assetsRoot": "./assets",
  "designDirection": [
    "dark-first",
    "cinematic",
    "developer-first",
    "glass surfaces",
    "single-accent emphasis"
  ],
  "fonts": {
    "display": {
      "name": "Tomato Grotesk",
      "role": "headlines, nav, CTA, product labels",
      "files": [
        "./assets/fonts/Tomato/Tomato Grotesk Light.woff2",
        "./assets/fonts/Tomato/Tomato Grotesk Light Slanted.woff2",
        "./assets/fonts/Tomato/Tomato Grotesk Regular.woff2",
        "./assets/fonts/Tomato/Tomato Grotesk Regular Slanted.woff2",
        "./assets/fonts/Tomato/Tomato Grotesk Semibold.woff2"
      ]
    },
    "body": {
      "name": "Neue Haas Unica",
      "role": "paragraphs, support copy, longer reading surfaces",
      "files": [
        "./assets/fonts/NeueHaas/NeueHaasUnicaW1G-Light.woff2",
        "./assets/fonts/NeueHaas/NeueHaasUnicaW1G-LightIt.woff2",
        "./assets/fonts/NeueHaas/NeueHaasUnicaW1G-Regular.woff2",
        "./assets/fonts/NeueHaas/NeueHaasUnicaW1G-Medium.woff2",
        "./assets/fonts/NeueHaas/NeueHaasUnicaW1G-MediumIt.woff2"
      ]
    },
    "mono": {
      "name": "JetBrains Mono Nerd Font",
      "role": "code, terminals, data labels, snippets",
      "files": [
        "./assets/fonts/mono/JetBrainsMonoNLNerdFont-Regular.woff2"
      ]
    },
    "availableButNotPrimary": [
      {
        "name": "Power Grotesk",
        "reason": "Font files are bundled locally, but the current font-power utility in the source app points at Tomato Grotesk."
      },
      {
        "name": "Season Mix",
        "reason": "Token exists in app.css, but there is no loaded @font-face."
      },
      {
        "name": "Commit Mono",
        "reason": "Naming exists, but the actually loaded mono face is JetBrains Mono Nerd Font."
      }
    ]
  },
  "colors": {
    "semantic": {
      "background": "hsl(0 0% 5%)",
      "foreground": "hsl(0 0% 98%)",
      "muted": "hsl(0 0% 14.9%)",
      "mutedForeground": "hsl(0 0% 63.9%)",
      "card": "hsl(0 0% 9%)",
      "cardForeground": "hsl(0 0% 98%)",
      "border": "hsl(0 0% 14.9%)",
      "input": "hsl(0 0% 14.9%)",
      "primary": "hsl(0 0% 98%)",
      "primaryForeground": "hsl(0 0% 9%)",
      "secondary": "hsl(0 0% 14.9%)",
      "secondaryForeground": "hsl(0 0% 98%)",
      "destructive": "hsl(0 84.2% 60.2%)"
    },
    "brand": {
      "moss": "#8BFFC6",
      "mossSoft": "#CDEEB5",
      "mossDark": "#2A2D27",
      "papaya": "#FFAB96",
      "papayaDark": "#3A231E",
      "mountain": "#B4C1EE",
      "darkMountain": "#22232A",
      "mango": "#E3EC9F",
      "mangoDark": "#2A2F1D",
      "banana": "#FFE551",
      "rayonlabs": "#FFACA3",
      "ether": "#88FFB7",
      "pro": "#FFD9A7"
    },
    "ink": {
      "900": "#0C0C0C",
      "800": "#121212",
      "700": "#151515",
      "600": "#292929",
      "500": "#343434",
      "400": "#4A4A4A",
      "300": "#9C9C9C",
      "200": "#C4C4C4",
      "100": "#E0E0E0"
    },
    "gradient": {
      "brandHighlight": "linear-gradient(135deg, #8BFFC6 0%, #FDA4AF 60%, #6366F1 100%)"
    }
  },
  "radii": {
    "baseToken": "0.5rem",
    "common": {
      "pill": "999px",
      "control": "10px",
      "card": "16px",
      "featurePanel": "24px"
    }
  },
  "motion": {
    "ambient": [
      "slow looping hero videos",
      "glass blur overlays",
      "marquee text",
      "subtle spin and hue rotation"
    ],
    "tokens": {
      "scrollX": "20s linear infinite",
      "hueRotate": "12s linear infinite",
      "parachuteFall": "3s ease-out",
      "parachuteFallSlow": "10s ease-in-out",
      "spinSlow": "3s linear infinite"
    }
  },
  "components": {
    "buttons": {
      "default": "bright fill, dark text, pill radius",
      "outline": "transparent fill, muted border, light text",
      "moss": "soft green fill, green border, green text",
      "papaya": "soft papaya fill, papaya border, papaya text"
    },
    "surfaces": {
      "page": "ink-900 or ink-800",
      "panel": "dark translucent surface with soft border",
      "hero": "large radius container with motion background",
      "card": "rounded-xl or rounded-2xl with light border"
    },
    "badges": {
      "launch": "solid moss pill",
      "status": "moss/10 chip with moss text",
      "secondary": "papaya or ink variant"
    },
    "forms": {
      "fields": "tall rounded controls with translucent gray fill",
      "focus": "subtle moss ring"
    }
  },
  "logos": {
    "primaryMarkLight": "./assets/brand/chutes-flat-light.svg",
    "primaryMarkDark": "./assets/brand/chutes-flat-dark.svg",
    "secondaryMark": "./assets/brand/chutesblock.webp",
    "favicon": "./assets/brand/favicon.png",
    "opengraphFallback": "./assets/brand/chutes-opengraph.webp",
    "componentSource": "./assets/icon-source/ChutesFlat.svelte"
  },
  "icons": {
    "utility": "@lucide/svelte",
    "custom": "./assets/icon-source",
    "providerComponents": "./assets/icon-source/providers",
    "providerLogoWall": "./assets/logos/providers-bw"
  },
  "assetFamilies": {
    "heroMotion": [
      "./assets/media/hero/testnew.mp4",
      "./assets/media/hero/hero-poster.webp",
      "./assets/media/hero/decentracube.mp4",
      "./assets/media/hero/platformdecentracubeposter.webp",
      "./assets/media/ambient/fallingcubes.mp4",
      "./assets/media/ambient/fallingchute-poster.webp"
    ],
    "partnerLogos": [
      "./assets/logos/partners/openrouter.png",
      "./assets/logos/partners/cline.png",
      "./assets/logos/partners/kilo.png",
      "./assets/logos/partners/roocode.png",
      "./assets/logos/partners/fetchai.webp",
      "./assets/logos/partners/deepfakeai.png"
    ],
    "providerLogos": [
      "./assets/logos/providers-bw/deepseek.png",
      "./assets/logos/providers-bw/openai.png",
      "./assets/logos/providers-bw/mistralai.png",
      "./assets/logos/providers-bw/qwen.png",
      "./assets/logos/providers-bw/microsoft.png",
      "./assets/logos/providers-bw/gemma.png",
      "./assets/logos/providers-bw/templar.png",
      "./assets/logos/providers-bw/kimik2.png"
    ],
    "photography": [
      "./assets/images/hyperscale/devs.jpg",
      "./assets/images/hyperscale/hyperfast.jpg",
      "./assets/images/hyperscale/decentralised.jpg"
    ],
    "shareCards": [
      "./assets/social"
    ],
    "productStills": [
      "./assets/images/product/platformscreen.jpg",
      "./assets/images/product/platform-screenie.webp",
      "./assets/images/product/research-graphic.webp",
      "./assets/images/product/imagemodels.webp",
      "./assets/images/product/moviemodels.webp",
      "./assets/images/product/voicemodels.webp",
      "./assets/images/product/musicmodels.webp"
    ],
    "cardArt": [
      "./assets/images/cards/base-card.webp",
      "./assets/images/cards/plus-card.webp",
      "./assets/images/cards/pro-card.webp",
      "./assets/images/cards/enterprise-card.webp",
      "./assets/images/cards/free-card.webp",
      "./assets/images/cards/flexchutes.webp",
      "./assets/images/cards/chutesblocks.webp",
      "./assets/images/cards/chuter3.webp"
    ]
  },
  "notes": [
    "The package intentionally includes local asset copies so it remains portable.",
    "The repo currently carries both bright moss and a softer legacy moss.",
    "Use moss sparingly but decisively for active state and emphasis.",
    "Keep gradients for hero moments rather than everyday UI."
  ]
}
